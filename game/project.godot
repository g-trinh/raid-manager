; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Raid Manager"
config/features=PackedStringArray("4.6", "Forward Plus")
run/main_scene="res://scenes/draft/draft_screen.tscn"

[autoload]

GameData="*res://scripts/autoloads/game_data.gd"
DraftState="*res://scripts/autoloads/draft_state.gd"
RunState="*res://scripts/autoloads/run_state.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")
